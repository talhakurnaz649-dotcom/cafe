@page
@model cafe.Pages.LoginModel
@{
    ViewData["Title"] = "Yönetici Girişi - Endles Cafe";
}

<div class="container my-5">
    <div class="cart-container" style="max-width: 450px; margin: 0 auto; padding: 3rem 2rem;">
        <div class="text-center mb-4">
            <i class="bi bi-shield-lock" style="font-size: 3.5rem; color: var(--accent);"></i>
            <h1 style="font-family: var(--font-heading); font-size: 2rem;" class="mt-2">Yönetici Girişi</h1>
            <p class="text-muted" style="font-size: 0.9rem;">Endles Cafe yönetim paneline erişim için bilgilerinizi giriniz.</p>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger text-center py-2" role="alert" 
                 style="background-color: rgba(178, 83, 83, 0.2); border-color: var(--danger); color: var(--text-primary); font-size: 0.9rem; border-radius: 8px;">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @Model.ErrorMessage
            </div>
        }

        <form method="post">
            <div class="form-custom-group">
                <label asp-for="Username" class="form-custom-label">Kullanıcı Adı</label>
                <input asp-for="Username" class="form-custom-control" placeholder="admin" autofocus required />
                <span asp-validation-for="Username" class="text-danger" style="font-size: 0.8rem;"></span>
            </div>

            <div class="form-custom-group">
                <label asp-for="Password" class="form-custom-label">Şifre</label>
                <input asp-for="Password" class="form-custom-control" placeholder="••••••••" required />
                <span asp-validation-for="Password" class="text-danger" style="font-size: 0.8rem;"></span>
            </div>

            <button type="submit" class="btn btn-accent w-100 py-3 mt-3">Giriş Yap</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@page
@model cafe.Pages.MenuModel
@{
    ViewData["Title"] = "Menü - Endles Cafe";
}

<div class="container my-5">
    <div class="text-center mb-5">
        <h1 class="display-4" style="font-family: var(--font-heading);">Nefis Menümüz</h1>
        <p style="color: var(--text-secondary); max-width: 600px; margin: 0 auto;">
            Baristalarımızın elinden taze taze demlenen kahveler ve günlük hazırlanan enfes tatlılar.
        </p>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show text-center mb-4" role="alert" 
             style="background-color: rgba(109, 142, 100, 0.2); border-color: var(--success); color: var(--text-primary); border-radius: 12px;">
            <i class="bi bi-check-circle-fill me-2" style="color: var(--success);"></i> @TempData["Message"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Kapat"></button>
        </div>
    }

    <!-- Category Selector Tabs -->
    <div class="text-center">
        <ul class="nav nav-tabs menu-tabs" role="tablist">
            <li class="nav-item">
                <a class="nav-link @(string.IsNullOrEmpty(Model.SelectedCategory) || Model.SelectedCategory == "Hepsi" ? "active" : "")" 
                   asp-page="/Menu" asp-route-SelectedCategory="Hepsi">Hepsi</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(Model.SelectedCategory == "Kahve" ? "active" : "")" 
                   asp-page="/Menu" asp-route-SelectedCategory="Kahve">🌯 Kahveler</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(Model.SelectedCategory == "Tatlı" ? "active" : "")" 
                   asp-page="/Menu" asp-route-SelectedCategory="Tatlı">🍰 Tatlılar</a>
            </li>
        </ul>
    </div>

    <!-- Menu Items Grid -->
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
        @if (Model.Products != null && Model.Products.Any())
        {
            @foreach (var product in Model.Products)
            {
                <div class="col">
                    <div class="cafe-card">
                        @if (!string.IsNullOrEmpty(product.ImageUrl))
                        {
                            <img src="@product.ImageUrl" alt="@product.Name" class="cafe-card-img" />
                        }
                        else
                        {
                            <div class="cafe-card-img d-flex align-items-center justify-content-center bg-dark text-muted" style="font-size: 3rem;">
                                ☕
                            </div>
                        }
                        <div class="cafe-card-body">
                            <h3 class="cafe-card-title">@product.Name</h3>
                            <p class="cafe-card-desc">@product.Description</p>
                            <div class="cafe-card-footer">
                                <span class="cafe-card-price">₺@product.Price.ToString("F2")</span>
                                <form method="post" asp-page-handler="AddToCart">
                                    <input type="hidden" name="productId" value="@product.Id" />
                                    <button type="submit" class="btn btn-accent btn-sm d-flex align-items-center gap-2 px-3 py-2">
                                        <i class="bi bi-cart-plus" style="font-size: 1.1rem;"></i> Ekle
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <p class="text-muted" style="font-size: 1.2rem;">Bu kategoride henüz aktif ürün bulunmuyor.</p>
            </div>
        }
    </div>
</div>

@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Endles Cafe</title>
    
    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet">
    
    <!-- Custom Style Sheet -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark navbar-custom">
            <div class="container">
                <a class="navbar-brand navbar-brand-custom" asp-page="/Index">ENDLES <span>CAFE</span></a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" 
                        aria-controls="navbarNav" aria-expanded="false" aria-label="Navigasyonu Aç">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom @(ViewContext.RouteData.Values["page"]?.ToString() == "/Index" ? "active" : "")" asp-page="/Index">Ana Sayfa</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom @(ViewContext.RouteData.Values["page"]?.ToString() == "/Menu" ? "active" : "")" asp-page="/Menu">Menü</a>
                        </li>
                    </ul>
                    <div class="d-flex align-items-center">
                        <a class="btn-outline-accent me-3 py-2 px-3 d-flex align-items-center gap-2" asp-page="/Cart">
                            <i class="bi bi-cart3"></i> Sepetim
                        </a>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <div class="dropdown">
                                <button class="btn btn-accent dropdown-toggle py-2 px-3 d-flex align-items-center gap-2" type="button" id="adminDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-gear"></i> Yönetici
                                </button>
                                <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end" aria-labelledby="adminDropdown" style="background-color: var(--bg-secondary); border: 1px solid var(--bg-tertiary);">
                                    <li><a class="dropdown-item" asp-page="/Admin/Dashboard">Panel</a></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/Products/Index">Ürün Yönetimi</a></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/Orders">Siparişler</a></li>
                                    <li><hr class="dropdown-divider" style="border-color: var(--bg-tertiary);"></li>
                                    <li><a class="dropdown-item text-danger" asp-page="/Login" asp-page-handler="Logout">Güvenli Çıkış</a></li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a class="nav-link nav-link-custom" asp-page="/Login"><i class="bi bi-person"></i> Giriş</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="footer-custom">
        <div class="container">
            <div class="footer-logo">ENDLES CAFE</div>
            <div class="footer-links">
                <a asp-page="/Index">Ana Sayfa</a>
                <a asp-page="/Menu">Menü</a>
                <a asp-page="/Cart">Sepetim</a>
                <a asp-page="/Login">Yönetici Girişi</a>
            </div>
            <p class="mb-0 text-muted">&copy; 2026 - Endles Cafe - Tüm Hakları Saklıdır.</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
